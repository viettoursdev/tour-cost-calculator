rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isEmployee() {
      // email_verified is intentionally NOT required. Magic-link sign-ins
      // are auto-verified; Email+Password sign-ins (DEV testing) start
      // unverified and the verification flow adds friction with no real
      // security gain. The domain regex below is the load-bearing check,
      // and Firebase Auth accounts in this project are created only by
      // an admin in the Console.
      return request.auth != null
        && request.auth.token.email.lower().matches('.*@viettours[.]com[.]vn$');
    }

    // Internal tool: any authenticated @viettours.com.vn employee may read and
    // write every collection (rate card, users, quotes, contracts, customers,
    // NCC, notifications, notification_threads, tour_payments, itineraries,
    // menus, visa, payment_approvals, …). Anonymous and external-domain clients
    // are denied across the board.
    //
    // A previous per-collection allowlist silently denied newer collections
    // (notification_threads, tour_payments, …), which broke notifications,
    // payment sync, itineraries and menus. Phase 4 may re-introduce granular
    // per-collection rules — but they must cover EVERY collection the app uses.
    match /{document=**} { allow read, write: if isEmployee(); }
  }
}
